<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.biztory.tableau-self-service-support" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>Submit support requests directly from Tableau as GitHub Issues</description>
    <author name="Biztory" email="support@biztory.com" organization="Biztory" website="https://biztory.com"/>
    <min-api-version>1.7</min-api-version>
    <source-location>
      <url>http://localhost:8766</url>
    </source-location>
    <icon></icon>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">Biztory 1st level Tableau AI Support</text>
    </resource>
  </resources>
</manifest>
